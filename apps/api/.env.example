# ─────────────────────────────────────────────────────────────────────────────
# LawLens API — Environment Variables
# Mirrors root .env.example. In development, symlink or copy root .env here.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
SECRET_KEY=replace-with-a-long-random-secret

ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
COHERE_API_KEY=

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

DATABASE_URL=postgresql+asyncpg://lawlens:lawlens@localhost:5432/lawlens
DATABASE_URL_SYNC=postgresql://lawlens:lawlens@localhost:5432/lawlens

REDIS_URL=redis://localhost:6379

CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

EMBEDDING_MODEL=voyage-law-2
EMBEDDING_DIMENSIONS=1024
ENABLED_JURISDICTIONS=india,uk,canada,australia
