# ─────────────────────────────────────────────────────────────────────────────
# LawLens — Root Environment Variables
# Copy this file to .env and fill in the values.
# Frontend-specific vars live in apps/web/.env.local
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
SECRET_KEY=replace-with-a-long-random-secret

# ─── AI — OpenRouter (LLM gateway — claude-sonnet-4-6 for Q&A, haiku for routing) ──
# Required for all modes (RAG and LLM-only fallback)
# Get key at: https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── AI — Voyage (Legal Embeddings) ──────────────────────────────────────────
# Required for RAG mode. voyage-law-2 is purpose-built for legal text retrieval.
# Get key at: https://www.voyageai.com/
# Without this key, LawLens falls back to LLM-only mode (no retrieval).
VOYAGE_API_KEY=

# ─── AI — Cohere (Cross-Encoder Reranker) ────────────────────────────────────
# Optional but strongly recommended. Improves answer quality via reranking.
# Get key at: https://cohere.com/
COHERE_API_KEY=

# ─── Vector Database — Qdrant ─────────────────────────────────────────────────
# Required for RAG mode. Run locally: docker run -p 6333:6333 qdrant/qdrant
# Or use Qdrant Cloud: https://cloud.qdrant.io/
# After setting up Qdrant, run: pnpm ingest  (to populate with legal documents)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Database — PostgreSQL ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lawlens:lawlens@localhost:5432/lawlens
DATABASE_URL_SYNC=postgresql://lawlens:lawlens@localhost:5432/lawlens

# ─── Cache — Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth — Clerk ─────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ─── Storage — Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Embeddings Config ────────────────────────────────────────────────────────
EMBEDDING_MODEL=voyage-law-2
EMBEDDING_DIMENSIONS=1024

# ─── Jurisdictions ────────────────────────────────────────────────────────────
ENABLED_JURISDICTIONS=india,uk,canada,australia
